{
  "uid": "champy-predictions",
  "title": "Champy - Prédictions",
  "description": "Distribution des espèces prédites, confiance moyenne, et histogramme des confiances. Utile pour détecter une dérive de distribution (proxy drift) ou une chute de confiance globale.",
  "tags": [
    "champy",
    "predictions",
    "drift"
  ],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "id": 1,
      "type": "barchart",
      "title": "Top-10 espèces prédites (cumulatif)",
      "gridPos": {
        "h": 10,
        "w": 16,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "topk(10, sum by (species) (champy_predictions_total))",
          "legendFormat": "{{species}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "auto",
        "stacking": "none",
        "xTickLabelRotation": 0,
        "legend": {
          "showLegend": false
        }
      },
      "description": "Les dix espèces de champignons les plus fréquemment prédites par le modèle depuis le démarrage. Une distribution très déséquilibrée peut révéler un biais du modèle ou une dérive des images entrantes (proxy drift)."
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Confiance moyenne (top-1)",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "champy_prediction_confidence_sum / champy_prediction_confidence_count",
          "legendFormat": "avg",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "green",
                "value": 0.85
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "description": "Score de confiance moyen de la classe la plus probable (top-1) sur l'ensemble des prédictions. Une baisse durable peut signaler des images hors-distribution ou une dégradation du modèle."
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Espèces uniques observées",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 16,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "count(count by (species) (champy_predictions_total))",
          "legendFormat": "n",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "description": "Nombre d'espèces distinctes prédites au moins une fois. Donne une idée de la diversité des entrées réellement traitées par l'API."
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Prédictions par seconde (par espèce, top-5)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "topk(5, sum by (species) (rate(champy_predictions_total[1m])))",
          "legendFormat": "{{species}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "description": "Débit de prédictions pour les cinq espèces les plus actives, calculé en temps réel. Met en évidence les classes les plus sollicitées."
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Latence par espèce (p95, top 5)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(champy_prediction_latency_seconds_bucket[5m])))",
          "legendFormat": "p95 global",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "description": "Latence au 95e percentile pour les cinq espèces les plus prédites. Permet de repérer une classe dont le traitement serait anormalement lent."
    }
  ]
}
