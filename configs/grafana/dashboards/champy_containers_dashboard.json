{
  "uid": "champy-containers",
  "title": "Champy - Ressources containers",
  "description": "Monitoring des ressources (CPU, RAM, IO) des containers du projet Champy, alimenté par l'exporter basé sur l'API Docker (contournement de l'incompatibilité cAdvisor / containerd snapshotter).",
  "tags": [
    "champy",
    "docker",
    "ressources"
  ],
  "schemaVersion": 39,
  "version": 2,
  "editable": true,
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "container",
        "label": "Container",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(docker_container_cpu_percent{name=~\"champy_.*\"}, name)",
          "refId": "var"
        },
        "includeAll": true,
        "multi": true,
        "allValue": "champy_.*",
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 8,
      "type": "text",
      "title": "À propos de ce tableau de bord",
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "**Ressources consommées par les containers du projet Champy**, mesurées via l'API Docker (exporter maison, contournement de l'incompatibilité cAdvisor / containerd). Filtré par défaut sur les containers `champy_` ; ajuste la variable **Container** en haut pour cibler un service précis.\n\n- **Containers actifs** : nombre de containers Champy en cours d'exécution.\n- **CPU par container (%)** : charge processeur de chaque container.\n- **Mémoire utilisée (octets / %)** : RAM consommée en absolu et en part de la limite.\n- **Débit réseau / disque (octets/s)** : trafic et E/S par container.\n- **Récapitulatif** : vue instantanée triée par CPU, colorée selon la charge."
      },
      "transparent": false
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Containers actifs",
      "description": "Nombre de containers Champy en état running (docker_container_up == 1).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "count(docker_container_up{name=~\"$container\"} == 1)",
          "legendFormat": "actifs",
          "refId": "A",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU par container (%)",
      "description": "Pourcentage CPU par container, calculé sur le delta d'usage CPU entre deux collectes (compatible cgroup v2).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 18,
        "x": 6,
        "y": 5
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "docker_container_cpu_percent{name=~\"$container\"}",
          "legendFormat": "{{name}}",
          "refId": "A",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Mémoire utilisée (octets)",
      "description": "Mémoire réellement utilisée par container (usage moins inactive_file, conformément à cgroup v2).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "docker_container_memory_usage_bytes{name=~\"$container\"}",
          "legendFormat": "{{name}}",
          "refId": "A",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Mémoire utilisée (%)",
      "description": "Pourcentage de la limite mémoire consommé par container. Utile pour repérer les containers proches de leur plafond.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "docker_container_memory_percent{name=~\"$container\"}",
          "legendFormat": "{{name}}",
          "refId": "A",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Débit réseau (octets/s)",
      "description": "Débit réseau entrant (rx) et sortant (tx) par container, dérivé via rate() des compteurs cumulatifs Docker.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 21
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(docker_container_network_rx_bytes{name=~\"$container\"}[$__rate_interval])",
          "legendFormat": "rx {{name}}",
          "refId": "A",
          "format": "time_series"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(docker_container_network_tx_bytes{name=~\"$container\"}[$__rate_interval])",
          "legendFormat": "tx {{name}}",
          "refId": "B",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Débit disque (octets/s)",
      "description": "Débit d'E/S disque en lecture et écriture par container, dérivé via rate() des compteurs cumulatifs Docker. Peut être vide en cgroup v2 selon la config.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 21
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(docker_container_block_read_bytes{name=~\"$container\"}[$__rate_interval])",
          "legendFormat": "read {{name}}",
          "refId": "A",
          "format": "time_series"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(docker_container_block_write_bytes{name=~\"$container\"}[$__rate_interval])",
          "legendFormat": "write {{name}}",
          "refId": "B",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Récapitulatif par container",
      "description": "Vue instantanée triée : CPU %, mémoire utilisée et % mémoire par container. Permet de repérer d'un coup d'œil les plus gros consommateurs.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 29
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "docker_container_cpu_percent{name=~\"$container\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "docker_container_memory_usage_bytes{name=~\"$container\"}",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "docker_container_memory_percent{name=~\"$container\"}",
          "format": "table",
          "instant": true,
          "refId": "C"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "service": true
            },
            "renameByName": {
              "name": "Container",
              "Value #A": "CPU (%)",
              "Value #B": "RAM (octets)",
              "Value #C": "RAM (%)"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "sort": [
              {
                "field": "CPU (%)",
                "desc": true
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "RAM (octets)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bytes"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "CPU (%)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 50
                    },
                    {
                      "color": "red",
                      "value": 80
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "RAM (%)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true
      }
    }
  ]
}
