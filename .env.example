# ============================================================
# Champy Classifier - variables d'environnement (modele)
# Copier en .env puis renseigner les valeurs.
# ============================================================

# -- MLflow tracking --
# MLflow local (conteneur du compose) : valeur par defaut.
MLFLOW_TRACKING_URI=http://localhost:5050
# Pour un serveur MLflow distant protege par mot de passe, renseigner :
# MLFLOW_TRACKING_USERNAME=
# MLFLOW_TRACKING_PASSWORD=

# -- MinIO (stockage artefacts MLflow, local) --
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_min_8_chars
MLFLOW_S3_ENDPOINT_URL=http://localhost:9010
# Acces S3 de MLflow vers MinIO : memes valeurs que MINIO_ROOT_*
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=changeme_min_8_chars
AWS_DEFAULT_REGION=us-east-1

# -- Airflow --
# Cle Fernet : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=changeme_fernet_key
AIRFLOW_WEBSERVER_SECRET=changeme_random_secret
AIRFLOW_ADMIN_PASSWORD=changeme_admin_password

# -- Grafana --
GRAFANA_PASSWORD=changeme

# -- URL publique (defaut local ; prod : https://champy.sbdg-ia.fr) --
CHAMPY_PUBLIC_BASE_URL=http://localhost:8088

# -- Discord (optionnel : relais d'alertes) --
DISCORD_WEBHOOK_URL=

# -- API --
API_HOST=0.0.0.0
API_PORT=8000
MODEL_PATH=models/model.onnx

# -- General --
ENVIRONMENT=development
LOG_LEVEL=INFO
SEED=42
