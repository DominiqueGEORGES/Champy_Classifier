# -- Data & Models (managed by DVC) --
# The .dvc pointer files (data.dvc, models.dvc) MUST stay in git.
# Only the actual data/model files are ignored.
/data/raw/
/data/processed/
/data/split/
# Donnees runtime (DB SQLite des predictions, generee par PredictionStore).
# On garde le .gitkeep pour que le repertoire existe au clone, mais les
# fichiers .db et leurs sidecars WAL/SHM ne doivent pas remonter dans git.
/data/runtime/*.db
/data/runtime/*.db-wal
/data/runtime/*.db-shm
/data/runtime/*.db-journal
# Rapports drift Evidently (generes a la demande, ~3-4 MB chacun, archive
# locale uniquement). La baseline JSON (~8 KB) reste tracee, elle, car
# elle est structurelle et reproduit l'ensemble du test set.
/monitoring/reports/drift_*.html
# Large source CSVs (DVC-managed), but keep pipeline artifacts
/data/observations_mushroom.csv
/data/dataset_30_species.csv
/data/champignons_france_top30.csv
/models/
*.onnx
*.pt
*.pth
*.keras
*.npy

