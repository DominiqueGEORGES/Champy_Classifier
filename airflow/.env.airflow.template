# Template pour airflow/.env.airflow
# Copier ce fichier en .env.airflow et remplir les valeurs marquées CHANGE_ME.
# Ne JAMAIS commit le .env.airflow (déjà gitignored).

# --- Base de données Postgres dédiée à Airflow ---
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=CHANGE_ME
AIRFLOW_DB_NAME=airflow

# --- Compte administrateur Airflow Webserver ---
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME
AIRFLOW_ADMIN_EMAIL=user@example.com

# --- Secrets de chiffrement Airflow ---
# Générer FERNET_KEY avec :
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=CHANGE_ME_GENERATE_WITH_FERNET

# Générer WEBSERVER_SECRET avec :
#   python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_WEBSERVER_SECRET=CHANGE_ME_GENERATE_WITH_SECRETS

# --- Credentials MLflow (à recopier depuis le .env du projet) ---
# Par défaut, le pipeline vise le serveur MLflow auto-hébergé du compose.
MLFLOW_TRACKING_URI=http://localhost:5050
# Renseigner uniquement pour un serveur MLflow distant protégé :
MLFLOW_TRACKING_USERNAME=CHANGE_ME
MLFLOW_TRACKING_PASSWORD=CHANGE_ME
